# Actian / PostgreSQL-compatible connection
ACTIAN_DSN=postgresql://user:password@host:5432/database

# Optional API key gate for the query API
ACTIAN_QUERY_API_KEY=

# Embedding settings
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072
GEMINI_API_KEY=

# Query service settings
HOST=0.0.0.0
PORT=8000
TOP_K_DEFAULT=5
MAX_EXCERPT_CHARS=500
AUTO_INIT_SCHEMA=1
